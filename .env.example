# ─────────────────────────────────────────────────────────────────────────────
# CVonRAG — .env.example
# Copy to .env  →  cp .env.example .env
# NO paid API keys required anywhere in this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama ────────────────────────────────────────────────────────────────────
# docker-compose overrides this to http://ollama:11434 automatically
OLLAMA_BASE_URL=http://localhost:11434

# Pick based on your hardware:
#   qwen2.5:3b   → ~2 GB   (fast, CI/testing)
#   qwen2.5:7b   → ~5 GB   (good quality, dev)
#   qwen2.5:14b  → ~10 GB  (recommended)
#   qwen2.5:32b  → ~20 GB  (best, needs GPU)
OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Qdrant ────────────────────────────────────────────────────────────────────
# docker-compose overrides this to http://qdrant:6333 automatically
QDRANT_URL=http://localhost:6333
# For Qdrant Cloud (free tier at cloud.qdrant.io):
# QDRANT_URL=https://your-cluster.cloud.qdrant.io
# QDRANT_API_KEY=your_key_here
QDRANT_COLLECTION=gold_standard_cvs
QDRANT_VECTOR_SIZE=768

# ── RAG ───────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5

# ── Char-limit loop ───────────────────────────────────────────────────────────
CHAR_LOOP_MAX_ITERATIONS=4
CHAR_TOLERANCE=2

# ── LLM generation ────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
LLM_CONTEXT_WINDOW=8192

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
# Production: restrict to your frontend domain
# CORS_ORIGINS=["https://your-frontend.vercel.app"]
CORS_ORIGINS=["*"]
LOG_LEVEL=INFO
PORT=8000
