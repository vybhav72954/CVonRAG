# ─────────────────────────────────────────────────────────────────────────────
# CVonRAG — .env.example
# Copy to .env  →  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Hosted LLM provider selector ────────────────────────────────────────────
# Picks which hosted-LLM slot the runtime reads at request time.
#   "groq"       → reads GROQ_* below (default)
#   "openrouter" → reads OPENROUTER_* below
# Empty key on the selected slot falls back to Ollama. Embedding stays on
# Ollama either way (Groq/OpenRouter don't expose nomic-embed-text-compatible
# endpoints).
LLM_PROVIDER=groq

# ── Groq (primary) ──────────────────────────────────────────────────────────
# Set GROQ_API_KEY to route all LLM calls through Groq instead of local Ollama.
# Get a free key at https://console.groq.com → API Keys → Create API Key
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1
# Max bullets per /optimize request — applies to whichever hosted provider is
# active (Groq or OpenRouter). Both free tiers have strict per-minute limits.
# 15 bullets × 4 correction iterations = ~62 LLM calls ≈ 2 minutes worst-case.
# Raise this only if you have a paid plan.
# GROQ_MAX_BULLETS_PER_REQUEST=15

# ── OpenRouter (fallback) ──────────────────────────────────────────────────
# Insurance for a Groq outage on placement day. Set LLM_PROVIDER=openrouter
# to flip the runtime to this slot. Get a key at https://openrouter.ai → Keys
# OPENROUTER_API_KEY=sk-or-v1-your_key_here
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ollama (local fallback for LLM, always used for embeddings) ──────────────
# docker-compose overrides this to http://ollama:11434 automatically
OLLAMA_BASE_URL=http://localhost:11434

# Only used when GROQ_API_KEY is not set. Pick based on your hardware:
#   qwen2.5:3b   → ~2 GB   (fast, fits 4 GB GPU — safe default)
#   qwen2.5:7b   → ~5 GB   (good quality, dev)
#   qwen2.5:14b  → ~10 GB  (recommended quality — needs 12+ GB RAM)
#   qwen2.5:32b  → ~20 GB  (best, strong GPU only)
OLLAMA_LLM_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Qdrant ────────────────────────────────────────────────────────────────────
# docker-compose overrides this to http://qdrant:6333 automatically
QDRANT_URL=http://localhost:6333
# For Qdrant Cloud (free tier at cloud.qdrant.io):
# QDRANT_URL=https://your-cluster.cloud.qdrant.io
# QDRANT_API_KEY=your_key_here
QDRANT_COLLECTION=gold_standard_cvs
QDRANT_VECTOR_SIZE=768

# ── RAG ───────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5

# ── Char-limit loop ───────────────────────────────────────────────────────────
CHAR_LOOP_MAX_ITERATIONS=4
CHAR_TOLERANCE=2

# ── LLM generation ────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
LLM_CONTEXT_WINDOW=8192

# ── Bullet typewriter stream ──────────────────────────────────────────────────
# Inter-word delay (seconds) when streaming the finalized bullet to the browser.
# Set to 0 in CI to emit all chunks immediately.
BULLET_STREAM_CHUNK_DELAY=0.025

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
# Production: restrict to your frontend domain
# CORS_ORIGINS=["https://your-frontend.vercel.app"]

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Per-IP sliding-window limits. Protects hosted-LLM quota from scrapers / bad actors.
# Set to false in local dev if you want unrestricted access.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=60
RATE_LIMIT_PARSE=10
RATE_LIMIT_RECOMMEND=20
RATE_LIMIT_OPTIMIZE=5

# ── Admin auth ────────────────────────────────────────────────────────────
# Protect /ingest endpoint. Callers must send X-Ingest-Secret header.
# Leave blank/unset for open access (dev only). MUST set a real value before deploying.
# INGEST_SECRET=replace-with-a-long-random-string