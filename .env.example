# ─────────────────────────────────────────────────────────────────────────────
# CVonRAG — .env.example
# Copy to .env  →  cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Groq  ────────────────────────────
# Set GROQ_API_KEY to route all LLM calls through Groq instead of local Ollama.
# Get a free key at https://console.groq.com → API Keys → Create API Key
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (local fallback for LLM, always used for embeddings) ──────────────
# docker-compose overrides this to http://ollama:11434 automatically
OLLAMA_BASE_URL=http://localhost:11434

# Only used when GROQ_API_KEY is not set. Pick based on your hardware:
#   qwen2.5:3b   → ~2 GB   (fast, CI/testing)
#   qwen2.5:7b   → ~5 GB   (good quality, dev)
#   qwen2.5:14b  → ~10 GB  (recommended)
#   qwen2.5:32b  → ~20 GB  (best, needs GPU)
OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Qdrant ────────────────────────────────────────────────────────────────────
# docker-compose overrides this to http://qdrant:6333 automatically
QDRANT_URL=http://localhost:6333
# For Qdrant Cloud (free tier at cloud.qdrant.io):
# QDRANT_URL=https://your-cluster.cloud.qdrant.io
# QDRANT_API_KEY=your_key_here
QDRANT_COLLECTION=gold_standard_cvs
QDRANT_VECTOR_SIZE=768

# ── RAG ───────────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5

# ── Char-limit loop ───────────────────────────────────────────────────────────
CHAR_LOOP_MAX_ITERATIONS=4
CHAR_TOLERANCE=2

# ── LLM generation ────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=512
LLM_CONTEXT_WINDOW=8192

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
# Production: restrict to your frontend domain
# CORS_ORIGINS=["https://your-frontend.vercel.app"]

# ── Admin auth ────────────────────────────────────────────────────────────
# Protect /ingest endpoint. Callers must send X-Ingest-Secret header.
# Leave blank/unset for open access (dev only). MUST set a real value before deploying.
# INGEST_SECRET=replace-with-a-long-random-string