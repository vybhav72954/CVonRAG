# ── CVonRAG Frontend ──────────────────────────────────────────────────────────
# Copy to .env:  cp .env.example .env

# Local development (backend running on localhost)
VITE_API_URL=http://localhost:8000

# Production — set this in Vercel/Railway dashboard
# VITE_API_URL=https://cvonrag-api.onrender.com

# ── Google Workspace OAuth ───────────────────────────────────────────────────
# Web Client ID from Google Cloud Console → APIs & Services → Credentials.
# The same value must be configured server-side as GOOGLE_OAUTH_CLIENT_ID so
# the backend can verify the `aud` claim of incoming ID tokens.
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Institutional Workspace domain that restricts the sign-in account picker.
# This is a UX hint only — the backend enforces the same value via the `hd`
# claim check, so a tampered client cannot bypass it.
VITE_GOOGLE_OAUTH_HD=
